# ── Alpha Vantage ──────────────────────────────────────────
# Get your free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_key_here

# ── Webull ─────────────────────────────────────────────────
# Your Webull login credentials
WEBULL_EMAIL=your@email.com
WEBULL_PASSWORD=your_password
WEBULL_TRADING_PIN=123456     # Your 6-digit trading PIN

# ── Ollama / LM Studio ──────────────────────────────────────
# Default model to use — for LM Studio, set the host below
OLLAMA_MODEL=mistral
OLLAMA_HOST=http://127.0.0.1:1234

# ── Bot settings ───────────────────────────────────────────
# Starting paper trading balance
PAPER_BALANCE=25000

# Risk per trade as a percentage (e.g. 1 = 1%)
RISK_PER_TRADE_PCT=1.0

# Maximum number of open trades at once
MAX_OPEN_TRADES=6

# Watchlist — comma separated tickers to monitor
WATCHLIST=AAPL,MSFT,NVDA,AMD,META,GOOGL,AMZN,TSLA
