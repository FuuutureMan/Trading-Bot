# Webull login credentials
# Use these values when the bot needs live data or live trading via Webull.
WEBULL_EMAIL=your@email.com
WEBULL_PASSWORD=your_password
# Only required for live Webull trading.
WEBULL_TRADING_PIN=123456

# LM Studio settings
# If you run LM Studio locally, keep this default unless your host is different.
LM_STUDIO_MODEL=mistral
LM_STUDIO_HOST=http://127.0.0.1:1234

# Trading mode
# paper = simulated trading with a fake portfolio
# webull = live trading on your Webull account
BROKER_MODE=paper

# Starting paper trading balance for simulated mode
# Only used when BROKER_MODE=paper.
PAPER_BALANCE=25000

# Risk per trade as a percentage of portfolio value.
# Example: 1.0 means risk 1% of the portfolio on each trade.
RISK_PER_TRADE_PCT=1.0

# Maximum number of positions the bot can hold at once.
MAX_OPEN_TRADES=6

# Stock symbols the bot will scan.
# Separate tickers with commas, no spaces are required but allowed.
WATCHLIST=AAPL,MSFT,NVDA,AMD,META,GOOGL,AMZN,TSLA
